# Docker Compose Environment Configuration

# HAProxy Stats Interface
HAPROXY_STATS_PORT=8080
HAPROXY_STATS_URL=http://localhost:${HAPROXY_STATS_PORT}/stats

# Backend Servers (for internal network only)
BACKEND_1_PORT=8001
BACKEND_2_PORT=8002
BACKEND_3_PORT=8003

# HAProxy Configuration
HAPROXY_LOG_LEVEL=info
HAPROXY_MAX_CONN=4096

# Network Configuration
COMPOSE_PROJECT_NAME=haproxy-test
COMPOSE_NETWORK=haproxy-internal

# Health Check Configuration
HEALTH_CHECK_INTERVAL=5s
HEALTH_CHECK_TIMEOUT=2s
HEALTH_CHECK_RETRIES=3

# Container Resource Limits (optional)
# MEMORY_LIMIT=512m
# CPU_LIMIT=1.0
